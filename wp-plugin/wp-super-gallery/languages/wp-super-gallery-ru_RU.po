msgstr "Длительность переходов смены главного изображения и подсветки миниатюр."

#: includes/i18n/class-wpsg-frontend-strings.php:1519
msgid "Strip Position"
msgstr "Положение полосы"

#: includes/i18n/class-wpsg-frontend-strings.php:1520
msgid "Position of the thumbnail strip. 'Right' falls back to 'Below' on narrow containers."
msgstr "Положение полосы миниатюр. «Справа» переходит на «Снизу» в узких контейнерах."

#: includes/i18n/class-wpsg-frontend-strings.php:1521
msgid "Below"
msgstr "Снизу"

#: includes/i18n/class-wpsg-frontend-strings.php:1522
msgid "Right (wide containers)"
msgstr "Справа (широкие контейнеры)"

#: includes/i18n/class-wpsg-frontend-strings.php:1523
msgid "Hero Max Width"
msgstr "Максимальная ширина главного изображения"

