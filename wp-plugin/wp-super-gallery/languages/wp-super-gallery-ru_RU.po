msgid "Fill color used for the active dot."
msgstr "Цвет заливки, используемый для активной точки."

#: includes/i18n/class-wpsg-frontend-strings.php:1458
msgid "var(--wpsg-color-primary)"
msgstr "var(--wpsg-color-primary)"

#: includes/i18n/class-wpsg-frontend-strings.php:1460
msgid "Fill color used for inactive dots."
msgstr "Цвет заливки, используемый для неактивных точек."

#: includes/i18n/class-wpsg-frontend-strings.php:1461
msgid "rgba(128,128,128,0.4)"
msgstr "rgba(128,128,128,0.4)"

