{
  "name": "wp-super-gallery",
  "private": true,
  "version": "0.90.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:wp": "npm run i18n:generate && npm run build && node scripts/copy-wp-assets.js",
    "build:free": "WPSG_PREMIUM=false npm run build",
    "build:wp:free": "WPSG_PREMIUM=false npm run build:wp",
    "i18n:generate": "node scripts/generate-frontend-i18n.mjs",
    "i18n:check": "node scripts/generate-frontend-i18n.mjs --check",
    "i18n:check:locales": "node scripts/check-i18n-locales.mjs",
    "validate:themes": "node scripts/validate-themes.mjs",
    "validate:adapter-settings": "node scripts/validate-adapter-settings-parity.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:silent": "vitest run --silent",
    "test:watch": "vitest",
    "test:to-file": "vitest run --reporter=verbose --outputFile=vitest-results.txt",
    "test:triage": "vitest run --reporter=verbose --reporter=hanging-process --no-file-parallelism --silent",
    "test:quieter-triage": "vitest run --reporter=hanging-process --no-file-parallelism --silent",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "size-check": "node scripts/check-bundle-size.mjs",
    "check:free-build": "WPSG_PREMIUM=false npm run build && node scripts/check-free-build-clean.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "test:visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mantine/core": "^9.1.1",
    "@mantine/dates": "^9.1.1",
    "@mantine/form": "^9.1.1",
    "@mantine/hooks": "^9.1.1",
    "@mantine/modals": "^9.1.1",
    "@mantine/notifications": "^9.1.1",
    "@sentry/react": "^8.49.0",
    "@tabler/icons-react": "^3.36.1",
    "@tanstack/react-query": "^5.100.6",
    "chroma-js": "^3.2.0",
    "dayjs": "^1.11.19",
    "dockview": "^5.0.0",
    "dompurify": "^3.3.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "i18next": "^26.3.1",
    "immer": "^11.1.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-is": "^19.2.7",
    "react-photo-album": "^3.5.0",
    "react-rnd": "^10.5.2",
    "react-zoom-pan-pinch": "^3.7.0",
    "recharts": "^3.7.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-docs": "^10.4.3",
    "@storybook/react": "^10.4.3",
    "@storybook/react-vite": "^10.4.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/chroma-js": "^3.1.2",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "eslint-plugin-storybook": "10.4.3",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.5.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass": "^1.77.8",
    "sass-embedded": "^1.77.8",
    "serve": "^14.2.6",
    "storybook": "^10.4.3",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.4.1",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "esbuild": ">=0.28.1"
  }
}
