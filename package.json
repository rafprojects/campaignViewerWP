{
  "name": "wp-super-gallery",
  "private": true,
  "version": "0.23.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:wp": "npm run build && node scripts/copy-wp-assets.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:silent": "vitest run --silent",
    "test:watch": "vitest",
    "test:to-file": "vitest run --reporter=verbose --outputFile=vitest-results.txt",
    "test:triage": "vitest run --reporter=verbose --reporter=hanging-process --no-file-parallelism --silent",
    "test:quieter-triage": "vitest run --reporter=hanging-process --no-file-parallelism --silent",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mantine/core": "^7.17.8",
    "@mantine/dates": "^7.17.8",
    "@mantine/form": "^7.17.8",
    "@mantine/hooks": "^7.17.8",
    "@mantine/modals": "^7.17.8",
    "@mantine/notifications": "^7.17.8",
    "@sentry/react": "^8.49.0",
    "@tabler/icons-react": "^3.36.1",
    "@tanstack/react-query": "^5.100.6",
    "chroma-js": "^3.2.0",
    "dayjs": "^1.11.19",
    "dockview": "^5.0.0",
    "dompurify": "^3.3.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "immer": "^11.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-photo-album": "^3.5.0",
    "react-rnd": "^10.5.2",
    "react-window": "^1.8.10",
    "react-zoom-pan-pinch": "^3.7.0",
    "recharts": "^3.7.0",
    "swr": "^2.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.51.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/chroma-js": "^3.1.2",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.5.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass": "^1.77.8",
    "sass-embedded": "^1.77.8",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.4.1",
    "vitest": "^2.1.8"
  }
}
