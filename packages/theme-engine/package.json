{
  "name": "@wp-super-gallery/theme-engine",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && rm -rf dist/definitions && cp -r src/definitions dist/definitions",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm -w @wp-super-gallery/shared-utils run build && npm run build"
  },
  "dependencies": {
    "@wp-super-gallery/shared-utils": "^1.0.0",
    "chroma-js": "^3.2.0"
  }
}
